### Read data from an excel file, use read_excel library
? read_excel
install.packages("shiny")
install.packages("ggplot2")
setwd("~/Desktop/CMU_SEM2/02604_Fundamentals of Bioinformatics/Project/Renal Tubules")
my_data <- readRDS("GSE182256_Export_counts.rds")
my_data <- readRDS("GSE182256_Export_counts.rds")
View(my_data)
write.csv(my_data, "output_data.csv", row.names = FALSE)
View(my_data)
my_data <- readRDS("GSE182256_Export_counts.rds")
write.csv(my_data, "output_data.csv", row.names = FALSE)
library(Matrix)
my_data <- readRDS("GSE182256_Export_counts.rds")
# If the RDS itself is a dgCMatrix
dense <- as.matrix(my_data)
# If genes are rows and cells are columns, rownames are often gene IDs
write.csv(dense, "output_data.csv", row.names = TRUE)
