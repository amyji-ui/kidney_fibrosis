Predicted.vs.Expert.Data.by.Image.April.2022 %>%
mutate(Genotype = fct_relevel(Genotype, c("WT", "ILK cKO"))) %>%
ggplot(aes(x = factor(Genotype), y = as.numeric(Jaccard), fill = factor(Genotype))) +
# add half-violin from (ggdist} package
ggdist::stat_halfeye(
side="left",
width = 0.3,
## custom bandwidth
adjust = 0.5,
## move geom to the right
justification = 1.5,
## remove slab interval
.width = 0,
point_colour = NA
) +
ylim(c(0,1)) +
scale_x_discrete(expand=expansion(mult=c(1,0.5))) +
geom_boxplot(
width = .2,
## remove outliers
outlier.color = NA,
alpha = 0.5
) +
ggdist::stat_dots(
side="right",
justification = -.2,
binwidth = .01
) +
# Adjust theme
scale_fill_tq(theme = "green") +
theme_tq(base_size = 20) +
theme(legend.position="none") +
labs(
x    = "",
y    = "Jaccard Index",
fill = ""
) +
geom_signif(comparisons = list(c("ILK cKO","WT")), y_position = 0.9,annotations="***")
